# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI= mongodb_URI
# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# EC2 target — pick one execution mode
EC2_EXEC_MODE=ssm                  # "ssm" or "ssh"
EC2_INSTANCE_ID=i-0123456789abcdef0
EC2_HOST=ec2-1-2-3-4.compute.amazonaws.com
EC2_USERNAME=ubuntu
EC2_SSH_PRIVATE_KEY_PATH=/absolute/path/to/key.pem

# Lambda
LAMBDA_FUNCTION_NAME=post-deploy-setup
LAMBDA_TEARDOWN_FUNCTION_NAME=post-teardown-cleanup

# Caddy
CADDY_ADMIN_URL=http://EC2_INTERNAL_IP:2019
CADDY_EMAIL=ops@ourplatform.com

# Frontend
FRONTEND_ORIGIN=http://localhost:5173

# Worker
WORKER_CONCURRENCY=2


